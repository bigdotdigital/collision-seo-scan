{
  "name": "collision-seo-scan",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start:web": "next start",
    "start:worker": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/worker.ts",
    "start": "next start",
    "lint": "next lint",
    "test:core": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/test-core.ts",
    "smoke:scan": "node scripts/smoke-scan.mjs",
    "seed:beta": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/seed-beta-testers.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "crawl:batch": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/crawl-batch.ts",
    "scan:metro": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/scan-metro.ts",
    "backfill:sources": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/backfill-source-observations.ts",
    "discover:denver": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/discover-denver-shops.ts",
    "repair:denver-discovery": "node --import ./scripts/register-path-alias.mjs --experimental-strip-types --experimental-specifier-resolution=node scripts/repair-denver-discovery.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "cheerio": "^1.0.0",
    "next": "14.2.32",
