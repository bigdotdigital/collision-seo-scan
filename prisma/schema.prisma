generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



model Scan {
  id                String      @id @default(cuid())
  createdAt         DateTime    @default(now())
  shopName          String
  city              String
  websiteUrl        String
  email             String?
  phone             String?
  scoreTotal        Int
  scoreWebsite      Int
  scoreLocal        Int
  scoreIntent       Int
  issuesJson        String
  moneyKeywordsJson String
  competitorsJson   String
  rawChecksJson     String
  pagespeedJson     String?
  aiSummary         String?
  thirtyDayPlanJson String?
  status            String      @default("lead")
  vertical          String      @default("collision")
  shopId            String?
  organizationId    String?
  scoringModelVersion String    @default("v0.1")
  componentScoresJson String?
  latestSnapshotId  String?
  clientId          String?
  bookedClicked     Boolean     @default(false)
  followupSent      Boolean     @default(false)
  shop              Shop?       @relation(fields: [shopId], references: [id], onDelete: SetNull)
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  client            Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  primaryForClient  Client?     @relation("PrimaryScan")
  queueJobs         QueueJob[]
  snapshots         ScanSnapshot[]
  rawResponses      RawProviderResponse[]
  leads             Lead[]
  keywordObservations ShopKeywordObservation[]
  competitorObservations ShopCompetitorObservation[]

  @@index([shopId])
  @@index([organizationId])
  @@index([vertical])
  @@index([createdAt])
}

model Client {
  id               String           @id @default(cuid())
  createdAt        DateTime         @default(now())
  shopName         String
  city             String
  websiteUrl       String
  ownerEmail       String
  ownerPhone       String?
  plan             String           @default("leadgen")
  isActive         Boolean          @default(true)
  notes            String?
  stripeCustomerId String?
  primaryScanId    String?          @unique
  portalPasswordHash String?
  scans            Scan[]
  metricSnapshots  MetricSnapshot[]
  keywords         Keyword[]
  queueJobs        QueueJob[]
  primaryScan      Scan?            @relation("PrimaryScan", fields: [primaryScanId], references: [id], onDelete: SetNull)
}

model MetricSnapshot {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  clientId     String
  keywordsJson String
  gscJson      String?
  gbpJson      String?
  reviewsJson  String?
  summaryJson  String
  scoreTotal   Int?
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Keyword {
  id         String     @id @default(cuid())
  clientId   String
  keyword    String
  city       String
  intentType String
  targetUrl  String?
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model QueueJob {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  runAt       DateTime
  type        String
  status      String    @default("pending")
  scanId      String?
  clientId    String?
  payloadJson String?
  attempts    Int       @default(0)
  processedAt DateTime?
  error       String?
  scan        Scan?     @relation(fields: [scanId], references: [id], onDelete: SetNull)
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model Shop {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  name             String
  websiteUrl       String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  lat              Float?
  lng              Float?
  googlePlaceId    String?  @unique
  primaryCategory  String?
  verticalDefault  String   @default("collision")
  scans            Scan[]
  organizations    Organization[]
  trackedAsCompetitor TrackedCompetitor[]
  keywordObservations ShopKeywordObservation[]
  competitorSourceObservations ShopCompetitorObservation[] @relation("ObservationSourceShop")
  competitorTargetObservations ShopCompetitorObservation[] @relation("ObservationTargetShop")

  @@index([name])
  @@index([city, state])
  @@index([websiteUrl])
}

model ShopKeywordObservation {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  observedAt  DateTime
  shopId      String
  scanId      String?
  keyword     String
  city        String?
  source      String
  searchType  String   @default("organic")
  rankPosition Int?
  searchVolume Int?
  cpcMicros   Int?
  confidence  String   @default("modeled")
  notes       String?
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  scan        Scan?    @relation(fields: [scanId], references: [id], onDelete: SetNull)

  @@index([shopId, observedAt])
  @@index([keyword, city, observedAt])
}

model ShopCompetitorObservation {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  observedAt     DateTime
  sourceShopId   String
  competitorShopId String
  scanId         String?
  source         String
  confidence     String   @default("modeled")
  relationshipType String @default("market_competitor")
  notes          String?
  sourceShop     Shop     @relation("ObservationSourceShop", fields: [sourceShopId], references: [id], onDelete: Cascade)
  competitorShop Shop     @relation("ObservationTargetShop", fields: [competitorShopId], references: [id], onDelete: Cascade)
  scan           Scan?    @relation(fields: [scanId], references: [id], onDelete: SetNull)

  @@index([sourceShopId, observedAt])
  @@index([competitorShopId, observedAt])
  @@index([sourceShopId, competitorShopId, observedAt])
}

model Organization {
  id               String   @id @default(cuid())
  shopId           String?
  name             String
  slug             String?  @unique
  websiteUrl       String?
  phone            String?
  address          String?
  city             String?
  state            String?
  zip              String?
  lat              Float?
  lng              Float?
  googlePlaceId    String?  @unique
  primaryCategory  String?
  verticalDefault  String   @default("collision")
  planTier         String   @default("monitor")
  agencyManaged    Boolean  @default(false)
  stripeCustomerId String?
  stripeSubscriptionId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  shop             Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  scans            Scan[]
  snapshots        ScanSnapshot[]
  providerCache    ProviderCache[]
  rawResponses     RawProviderResponse[]
  leads            Lead[]
  memberships      OrgMembership[]
  locations        Location[]
  trackedKeywords  TrackedKeyword[]
  trackedCompetitors TrackedCompetitor[]
  rankSnapshots    KeywordRankSnapshot[]
  alerts           Alert[]
  alertPreference  AlertPreference?
  subscription     Subscription?
  invoices         Invoice[]

  @@index([shopId])
  @@index([city, state])
  @@index([name])
}

model ScanSnapshot {
  id                     String   @id @default(cuid())
  createdAt              DateTime @default(now())
  scanId                 String
  organizationId         String
  scoringModelVersion    String   @default("v0.1")
  vertical               String   @default("collision")
  visibilityScore        Int
  reviewRating           Float?
  reviewCount            Int?
  reviewVelocity30d      Int?
  keywordsCheckedJson    String?
  rankPositionsJson      String?
  topCompetitorsJson     String?
  lostDemandEstimateJson String?
  recommendationsJson    String?
  scan                   Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([vertical, createdAt])
  @@index([scanId])
}

model RawProviderResponse {
  id             String   @id @default(cuid())
  fetchedAt      DateTime @default(now())
  scanId         String
  organizationId String?
  provider       String
  endpoint       String?
  requestHash    String?
  cacheKey       String?
  responseJson   String
  scan           Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([organizationId])
  @@index([scanId])
}

model ProviderCache {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String
  provider       String
  cacheKey       String
  lastFetchedAt  DateTime
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, cacheKey])
  @@index([expiresAt])
}

model Lead {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String
  scanId         String?
  email          String?
  phone          String?
  name           String?
  intent         String?
  budgetRange    String?
  timeline       String?
  vertical       String?
  consentedAt    DateTime?
  source         String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scan           Scan?     @relation(fields: [scanId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([organizationId, createdAt])
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  passwordHash String
  name         String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  memberships  OrgMembership[]
}

model OrgMembership {
  id        String         @id @default(cuid())
  orgId     String
  userId    String
  role      MembershipRole @default(owner)
  status    String         @default("active")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId, role])
  @@index([orgId, role])
}

model Location {
  id          String             @id @default(cuid())
  orgId       String
  name        String
  websiteUrl  String?
  gbpUrl      String?
  address     String?
  city        String?
  state       String?
  zip         String?
  serviceArea String?
  isPrimary   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  keywords    TrackedKeyword[]
  competitors TrackedCompetitor[]
  snapshots   KeywordRankSnapshot[]
  alerts      Alert[]

  @@index([orgId, isPrimary])
  @@index([orgId, city, state])
}

model TrackedKeyword {
  id         String                @id @default(cuid())
  orgId      String
  locationId String
  term       String
  isActive   Boolean               @default(true)
  source     String                @default("scanner")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  org        Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location   Location              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  snapshots  KeywordRankSnapshot[]

  @@unique([locationId, term])
  @@index([orgId, isActive])
}

model TrackedCompetitor {
  id         String                @id @default(cuid())
  orgId      String
  locationId String
  shopId     String?
  name       String
  websiteUrl String?
  gbpPlaceId String?
  isActive   Boolean               @default(true)
  source     String                @default("scanner")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  org        Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location   Location              @relation(fields: [locationId], references: [id], onDelete: Cascade)
  shop       Shop?                 @relation(fields: [shopId], references: [id], onDelete: SetNull)
  snapshots  KeywordRankSnapshot[]

  @@index([orgId, isActive])
  @@index([locationId, isActive])
  @@index([shopId])
}

model KeywordRankSnapshot {
  id           String             @id @default(cuid())
  orgId        String
  locationId   String
  keywordId    String
  competitorId String?
  snapshotDate DateTime
  rankPosition Int?
  delta        Int?
  source       String             @default("stub")
  rawJson      String?
  createdAt    DateTime           @default(now())
  org          Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location     Location           @relation(fields: [locationId], references: [id], onDelete: Cascade)
  keyword      TrackedKeyword     @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  competitor   TrackedCompetitor? @relation(fields: [competitorId], references: [id], onDelete: SetNull)

  @@index([orgId, snapshotDate])
  @@index([locationId, snapshotDate])
  @@index([keywordId, snapshotDate])
  @@index([competitorId, snapshotDate])
  @@unique([keywordId, competitorId, snapshotDate])
}

model Alert {
  id         String       @id @default(cuid())
  orgId      String
  locationId String?
  type       AlertType
  severity   AlertSeverity @default(info)
  payloadJson String
  isRead     Boolean      @default(false)
  createdAt  DateTime     @default(now())
  digestSentAt DateTime?
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location   Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt])
  @@index([orgId, isRead, createdAt])
  @@index([locationId, createdAt])
}

model AlertPreference {
  id                    String       @id @default(cuid())
  orgId                 String       @unique
  rankDropThreshold     Int          @default(3)
  rankGainThreshold     Int          @default(3)
  competitorMoveEnabled Boolean      @default(true)
  newCompetitorEnabled  Boolean      @default(true)
  gbpIssueEnabled       Boolean      @default(true)
  digestFrequency       DigestFrequency @default(daily)
  digestEmail           String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  org                   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String       @id @default(cuid())
  orgId                String       @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?      @unique
  planTier             String       @default("monitor")
  status               String       @default("trialing")
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String       @id @default(cuid())
  orgId           String
  stripeInvoiceId String       @unique
  amountCents     Int
  currency        String       @default("usd")
  status          String
  invoiceDate     DateTime
  hostedInvoiceUrl String?
  pdfUrl          String?
  createdAt       DateTime     @default(now())
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, invoiceDate])
}

enum MembershipRole {
  owner
  manager
  viewer
  agency_admin
}

enum AlertType {
  rank_drop
  rank_gain
  competitor_moved_above
  new_competitor
  gbp_issue
}

enum AlertSeverity {
  info
  warning
  critical
}

enum DigestFrequency {
  off
  daily
  weekly
}
